# ─────────────────────────────────────────────────────────────
# Cultural Heritage Backend — Environment Configuration Template
# Copy to ".env" and fill in real values before running.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# OpenRouter AI Integration
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"
AI_MODEL_NAME="openai/gpt-oss-120b:free"

# Static Master Key Protection
# Sent by the client via the "x-api-secret-key" header on /api/v1/chat.
# If left empty/omitted, the auth check is BYPASSED for local dev.
APP_DEMO_AUTH_SECRET="your_static_secret_key_here"

# Rate Limiting (per-IP)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# API Documentation Configuration
# Set to 'true' to show Scalar UI at /docs, or 'false' to hide it completely
SCALAR_DOCS_ENABLED=true

# CORS Configuration
# Isi dengan domain frontend resmi (contoh: https://www.yourdomain.com/).
# Jika dikosongkan, server akan mengizinkan semua origin (*) — hanya untuk development lokal.
CORS_ORIGIN=""
